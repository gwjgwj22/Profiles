wifi-access-socks5-port = 6153
# وک¯هگ¦ه…پè®¸ Wi-Fi ن¸‹ه…±ن؛«ç½‘ç»œ
allow-wifi-access = false
# èٹ‚ç‚¹وµ‹é€ںو—¶çڑ„è¶…و—¶ç§’و•°
test-timeout = 3
# ç½‘ç»œوژ¥هڈ£
